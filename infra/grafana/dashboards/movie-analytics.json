      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  toString(cohort_date) AS \"Cohort\",\n  coalesce(round(maxIf(retention_rate * 100, day_number = 0), 2), 0) AS \"Day 0\",\n  coalesce(round(maxIf(retention_rate * 100, day_number = 1), 2), 0) AS \"Day 1\",\n  coalesce(round(maxIf(retention_rate * 100, day_number = 2), 2), 0) AS \"Day 2\",\n  coalesce(round(maxIf(retention_rate * 100, day_number = 3), 2), 0) AS \"Day 3\",\n  coalesce(round(maxIf(retention_rate * 100, day_number = 4), 2), 0) AS \"Day 4\",\n  coalesce(round(maxIf(retention_rate * 100, day_number = 5), 2), 0) AS \"Day 5\",\n  coalesce(round(maxIf(retention_rate * 100, day_number = 6), 2), 0) AS \"Day 6\",\n  coalesce(round(maxIf(retention_rate * 100, day_number = 7), 2), 0) AS \"Day 7\"\nFROM analytics.retention_cohort_daily\nWHERE cohort_date <= today()\nGROUP BY cohort_date\nORDER BY cohort_date DESC\nLIMIT 30"
        }
      ],
      "title": "Retention Cohort Heatmap",
      "type": "table"
    },
